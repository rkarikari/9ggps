<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Greeting -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome, Explorer"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <!-- Live GPS status card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live GPS"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tvCurrentSpeed"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0 km/h" android:textSize="20sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Speed" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tvAltitude"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0 m" android:textSize="20sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Altitude" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tvAccuracy"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="±0 m" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Accuracy" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <ImageView android:id="@+id/ivDashCompass"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:src="@drawable/ic_compass"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Compass" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvCoordinates"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Acquiring fix..."
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="8dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tvSignalQuality"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No Fix"
                            android:textSize="12sp"
                            android:textColor="?attr/colorPrimary"/>

                        <TextView
                            android:id="@+id/tvRecordingStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• IDLE"
                            android:textSize="12sp"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Live track stats -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvLiveDistance"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 m" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Live Distance" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvLiveDuration"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0:00" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Live Duration" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Total Stats -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvTotalTracks"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Tracks" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvTotalDistance"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 m" android:textSize="20sp" android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Distance" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvTotalTime"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0:00" android:textSize="20sp" android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Time" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature cards grid -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Features" android:textSize="16sp" android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMap"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp"
                            android:src="@drawable/ic_map" android:tint="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Map" android:textSize="13sp" android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNavigation"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:layout_marginHorizontal="3dp"
                    app:cardCornerRadius="16dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp"
                            android:src="@drawable/ic_navigation" android:tint="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Navigate" android:textSize="13sp" android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTracks"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp"
                            android:src="@drawable/ic_track" android:tint="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tracks" android:textSize="13sp" android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWaypoints"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp"
                            android:src="@drawable/ic_waypoint" android:tint="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Waypoints" android:textSize="13sp" android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGeofences"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:layout_marginHorizontal="3dp"
                    app:cardCornerRadius="16dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp"
                            android:src="@drawable/ic_geofence" android:tint="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Geofences" android:textSize="13sp" android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHud"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp"
                            android:src="@drawable/ic_speed" android:tint="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="HUD" android:textSize="13sp" android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSpeedCamera"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp"
                            android:src="@drawable/ic_speed_camera" android:tint="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Speed Cams" android:textSize="13sp" android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSettings"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp"
                            android:src="@drawable/ic_settings" android:tint="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Settings" android:textSize="13sp" android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- GPS Satellite row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="6dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSatellite"
                    android:layout_width="match_parent" android:layout_height="100dp"
                    app:cardCornerRadius="16dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingHorizontal="20dp">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_gps_fixed" android:tint="?attr/colorPrimary"
                            android:layout_marginEnd="16dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="GPS Satellite Status" android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Sky view • Signal strength • All satellite details"
                                android:textSize="12sp" android:alpha="0.6" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_back"
                            android:rotation="180"
                            android:alpha="0.4"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
