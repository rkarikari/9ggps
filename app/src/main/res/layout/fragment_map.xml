<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Map View -->\n    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true" />

    <!--
         Invisible spacer whose height is set in code to the status-bar inset.
         All overlay cards that sit at the top of the screen are constrained
         to the BOTTOM of this spacer so they are never hidden by the status bar.
    -->
    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top gradient scrim -->
    <View
        android:id="@+id/topScrim"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/gradient_top_scrim"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Speed Card (top left) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBarSpacer">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="42sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                tools:ignore="HardcodedText"/>

            <TextView
                android:id="@+id/tvSpeedUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="km/h"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Compass Card (top left, below speed) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCompass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardSpeed">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivCompass"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_compass" />

            <TextView
                android:id="@+id/tvBearing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>

            <!-- Rotation-mode indicator: "N↑" (north-up) or "▶↑" (heading-up) -->
            <TextView
                android:id="@+id/tvOrientMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N↑"
                android:textColor="@color/accent_blue"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginTop="1dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!--
        Auto-Record Status Panel
        Visible only when home auto-record is enabled in Settings.
        Anchored below the compass card on the top-left so it never
        overlaps the GPS info or speed cards.
        States:
          • Monitoring (amber dot) — feature on, idle, watching for departure.
          • Auto-Recording (red dot) — trip was started automatically; shows
            live distance and duration from the existing trackStats flow.
    -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAutoRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardCompass">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical">

            <!-- Coloured status dot: amber = monitoring, red = auto-recording -->
            <TextView
                android:id="@+id/tvAutoRecordDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textSize="11sp"
                android:textColor="@color/accent_orange"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <!-- "Auto-Record" fixed label -->
                <TextView
                    android:id="@+id/tvAutoRecordLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-Record"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <!-- Dynamic status line: "Monitoring" or "1.2 km · 4:32" -->
                <TextView
                    android:id="@+id/tvAutoRecordStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monitoring"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- GPS Info Card (top right) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardGpsInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBarSpacer">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivGpsSignal"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_gps_fixed"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvSignalQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Fix"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAltitude"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 m"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvAccuracy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="±0m"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/tvSatellites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 sat"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Search Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBarSpacer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp">

                <androidx.appcompat.widget.SearchView
                    android:id="@+id/searchView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:queryHint="Search location..."
                    app:iconifiedByDefault="false"
                    app:searchIcon="@drawable/ic_search"/>

                <ImageButton
                    android:id="@+id/btnCloseSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    android:contentDescription="Close search"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/searchResultsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="300dp"
                android:visibility="gone"
                android:overScrollMode="never"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Route Preview Card (shown before navigation starts) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardRoutePreview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="6dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toTopOf="@id/cardNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Distance / ETA summary row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPreviewDistance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="-- km"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvPreviewEta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="-- min"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- Alternate routes horizontal list (visible only when > 1 route) -->
            <TextView
                android:id="@+id/tvAltRoutesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alternate routes"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

            <HorizontalScrollView
                android:id="@+id/scrollPreviewAlternates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:scrollbars="none"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPreviewAlternates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelRoute"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Cancel"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartNav"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start"
                    app:backgroundTint="@color/accent_blue"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Navigation Card (bottom) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardNavigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/nav_card_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toTopOf="@id/cardTrackStats"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Outer vertical wrapper so alternates row sits beneath the instructions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Maneuver + instructions + distance/ETA row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivNavManeuver"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_straight"
                    android:tint="@color/nav_text"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvNavInstruction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Continue straight"
                        android:textColor="@color/nav_text"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="2"/>

                    <TextView
                        android:id="@+id/tvNavNextInstruction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Then: Turn right"
                        android:textColor="@color/nav_text_secondary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvNavDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 m"
                        android:textColor="@color/nav_text"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvNavEta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ETA: --"
                        android:textColor="@color/nav_text_secondary"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvNavRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 km"
                        android:textColor="@color/nav_text_secondary"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!-- Stop-navigation button embedded in the card so it is always
                     reachable regardless of whether track recording is active.
                     The previous standalone btnStopNav was occluded by this card
                     whenever cardTrackStats was gone. -->
                <ImageButton
                    android:id="@+id/ibStopNav"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_close"
                    android:tint="@color/nav_text"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Stop navigation"
                    android:padding="6dp"/>
            </LinearLayout>

            <!-- Active alternate routes — only visible when OSRM returned > 1 route.
                 Lets the user switch routes without stopping navigation. -->
            <HorizontalScrollView
                android:id="@+id/scrollNavAlternates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:visibility="gone"
                android:scrollbars="none">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNavAlternates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Track Stats Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTrackStats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toTopOf="@id/bottomFabRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tvTrackDistance" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0.00 km"
                    android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Distance" android:textSize="10sp" android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tvTrackDuration" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0:00"
                    android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Duration" android:textSize="10sp" android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tvTrackAvgSpeed" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 km/h"
                    android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Avg" android:textSize="10sp" android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tvTrackMaxSpeed" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 km/h"
                    android:textSize="12sp" android:textStyle="bold" android:textColor="@color/accent_red"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Max" android:textSize="10sp" android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tvTrackElevation" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="+0 m"
                    android:textSize="12sp" android:textStyle="bold" android:textColor="@color/accent_green"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Gain" android:textSize="10sp" android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tvTrackCalories" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 kcal"
                    android:textSize="12sp" android:textStyle="bold" android:textColor="@color/accent_orange"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Kcal" android:textSize="10sp" android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Recording indicator -->
    <TextView
        android:id="@+id/tvRecordingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● REC"
        android:textColor="@color/accent_red"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/cardTrackStats"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Bottom FAB row -->
    <LinearLayout
        android:id="@+id/bottomFabRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="12dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSatellite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_gps_fixed"
            android:contentDescription="GPS Satellite Status"
            app:fabSize="mini"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_dashboard"
            android:contentDescription="Dashboard"
            app:fabSize="mini"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabLayers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_layers"
            android:contentDescription="Map layers"
            app:fabSize="mini"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_my_location"
            android:contentDescription="My location"
            app:fabSize="mini"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Search"
            app:fabSize="mini"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabRecordStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_stop"
            android:contentDescription="Stop recording"
            android:visibility="gone"
            app:backgroundTint="@color/accent_red"
            app:fabSize="mini"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabRecordToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_record"
            android:contentDescription="Record track"
            app:backgroundTint="@color/record_idle"/>
    </LinearLayout>

    <!-- btnStopNav removed: it was constrained to the same slot as cardNavigation
         and was permanently occluded by it when cardTrackStats was gone.
         Navigation is now stopped via ibStopNav inside cardNavigation. -->

    <!-- Weather Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardWeather"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/cardGpsInfo"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvWeatherTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvWeatherDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tvWeatherWind"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- m/s"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tvWeatherHumidity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--%"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
