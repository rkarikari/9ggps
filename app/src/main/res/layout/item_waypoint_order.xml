<?xml version="1.0" encoding="utf-8"?>
<!--
    Row used inside the "Route via waypoints" ordered-selection dialog.
    Left: waypoint name + coordinates.
    Right: circular badge that shows the stop number when selected, or a
    dimmed outline ring when unselected.  The whole row is clickable.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="3dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:strokeWidth="2dp"
    app:strokeColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <!-- Waypoint info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWpName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Waypoint Name"/>

            <TextView
                android:id="@+id/tvWpCoords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:text="0.00000, 0.00000"/>

        </LinearLayout>

        <!-- Stop-order badge: a 36×36 circle.
             - Unselected: outline ring (tvBadge text is empty, background = outline drawable)
             - Selected  : filled circle with the stop number as text               -->
        <TextView
            android:id="@+id/tvBadge"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
