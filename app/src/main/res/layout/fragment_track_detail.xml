<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Track Detail"
            app:navigationIcon="@drawable/ic_arrow_back"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <TextView
                android:id="@+id/tvTrackName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Track Name"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <TextView android:id="@+id/tvActivityType"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DRIVING" android:textSize="12sp" android:textColor="?attr/colorPrimary"
                    android:layout_marginEnd="12dp"/>
                <TextView android:id="@+id/tvDate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Jan 1, 2025" android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

            <!-- Mini Map with full-screen toggle -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginBottom="16dp">

                <org.osmdroid.views.MapView
                    android:id="@+id/miniMap"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <!-- Full-screen expand button -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnFullScreenMap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:contentDescription="Full screen map"
                    app:srcCompat="@drawable/ic_3d"
                    app:backgroundTint="?attr/colorSurface"
                    app:tint="?attr/colorOnSurface"
                    app:fabSize="mini"
                    app:elevation="4dp"/>

            </FrameLayout>

            <!-- Primary stats -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvDistance" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0.00 km"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Distance" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvDuration" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0:00"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="?attr/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Duration" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvPace" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--:-- /km"
                            android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pace" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Speed stats -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvAvgSpeed" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0 km/h"
                            android:textSize="20sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Avg Speed" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvMaxSpeed" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0 km/h"
                            android:textSize="20sp" android:textStyle="bold" android:textColor="@color/accent_red"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Max Speed" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvCalories" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0 kcal"
                            android:textSize="18sp" android:textStyle="bold" android:textColor="@color/accent_orange"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Calories" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Elevation stats -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvMinAlt" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0 m"
                            android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Min Alt" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvMaxAlt" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0 m"
                            android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Max Alt" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvElevGain" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="+0 m"
                            android:textSize="16sp" android:textStyle="bold" android:textColor="@color/accent_green"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Elev Gain" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvElevLoss" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="-0 m"
                            android:textSize="16sp" android:textStyle="bold" android:textColor="@color/accent_red"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Elev Loss" android:textSize="11sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════════════════════════
                 Synchronized cursor info bubble
                 Appears when the user touches either chart. Shows the data
                 values (distance, speed, elevation, time, progress) at the
                 exact cursor position, mirrored across both charts and the
                 mini-map.
            ════════════════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCursorInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="?attr/colorSecondaryContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="6dp">

                    <!-- Drag-hint label -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="● Cursor position"
                        android:textSize="10sp"
                        android:textStyle="italic"
                        android:textColor="?attr/colorOnSecondaryContainer"
                        android:alpha="0.7"
                        android:paddingStart="10dp"
                        android:layout_marginBottom="4dp"/>

                    <!-- Five stat cells in one row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Distance -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center" android:padding="4dp">
                            <TextView android:id="@+id/tvCursorDist"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textSize="14sp" android:textStyle="bold"
                                android:textColor="?attr/colorOnSecondaryContainer"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Dist" android:textSize="9sp"
                                android:textColor="?attr/colorOnSecondaryContainer" android:alpha="0.75"/>
                        </LinearLayout>

                        <!-- Speed -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center" android:padding="4dp">
                            <TextView android:id="@+id/tvCursorSpeed"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textSize="14sp" android:textStyle="bold"
                                android:textColor="?attr/colorOnSecondaryContainer"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Speed" android:textSize="9sp"
                                android:textColor="?attr/colorOnSecondaryContainer" android:alpha="0.75"/>
                        </LinearLayout>

                        <!-- Elevation -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center" android:padding="4dp">
                            <TextView android:id="@+id/tvCursorElev"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textSize="14sp" android:textStyle="bold"
                                android:textColor="?attr/colorOnSecondaryContainer"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Elev" android:textSize="9sp"
                                android:textColor="?attr/colorOnSecondaryContainer" android:alpha="0.75"/>
                        </LinearLayout>

                        <!-- Time elapsed -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center" android:padding="4dp">
                            <TextView android:id="@+id/tvCursorTime"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textSize="14sp" android:textStyle="bold"
                                android:textColor="?attr/colorOnSecondaryContainer"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Time" android:textSize="9sp"
                                android:textColor="?attr/colorOnSecondaryContainer" android:alpha="0.75"/>
                        </LinearLayout>

                        <!-- Progress -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center" android:padding="4dp">
                            <TextView android:id="@+id/tvCursorProgress"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textSize="14sp" android:textStyle="bold"
                                android:textColor="?attr/colorOnSecondaryContainer"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Done" android:textSize="9sp"
                                android:textColor="?attr/colorOnSecondaryContainer" android:alpha="0.75"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Elevation chart -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Elevation Profile" android:textSize="14sp" android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartElevation"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="16dp"/>

            <!-- Speed chart -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Speed Profile" android:textSize="14sp" android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartSpeed"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvPointCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 GPS points"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="16dp"/>

            <!-- Export buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportGpx"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Export GPX"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportKml"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:text="Export KML"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShare"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Share"
                    android:drawableStart="@drawable/ic_share"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
